# TankSync Transmitter — sdkconfig defaults (production)
#
# NOTE: ESP-IDF ignores CONFIG_ESP_WIFI_ENABLED=n in defaults.
# After `set-target esp32c3`, run:
#   sed -i '' 's/CONFIG_ESP_WIFI_ENABLED=y/# CONFIG_ESP_WIFI_ENABLED is not set/' sdkconfig

# Custom partition table with dual OTA slots (required for LoRa OTA)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# 4MB flash (ESP32-C3 SuperMini)
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# INT WDT: 800ms (not disabled) — tolerates systimer HAL glitch on C3 rev 0.4
# after deep sleep, while still catching real ISR hangs
CONFIG_ESP_INT_WDT=y
CONFIG_ESP_INT_WDT_TIMEOUT_MS=800

# Main task stack: 6KB (OTA path uses ~1.4KB in buffers alone)
CONFIG_ESP_MAIN_TASK_STACK_SIZE=6144

# OTA rollback: boot falls back to previous firmware if new one crashes
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# Debug optimization (-Og) — SIZE (-Os) triggers INT WDT on ESP32-C3
CONFIG_COMPILER_OPTIMIZATION_DEBUG=y

# Nano printf — saves ~10KB but breaks float format; we use integer millivolts
CONFIG_NEWLIB_NANO_FORMAT=y

# Log level: INFO for development, WARN for production releases
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_DEFAULT_LEVEL=3
