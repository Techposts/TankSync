 *
 * This file is included by config.h, which is included by every translation
 * unit, so FIRMWARE_VERSION is universally available. The CMake build also
 * sets PROJECT_VER from the same VERSION file, which propagates into the
 * esp_app_desc.version field at offset 0x30 of the compiled .bin — so the
 * web UI, OTA check, MQTT-reported version, and HACS firmware sensor all
 * read the same string. Discipline enforced by build system, not by humans.
 */
